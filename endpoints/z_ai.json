{
  "id": "z_ai",
  "match": {
    "schemes": ["https"],
    "host_equals": ["api.z.ai"],
    "ports": [443],
    "path_prefixes": ["/api/coding/paas/v4/"]
  },
  "models": {
    "method": "GET",
    "path": "models",
    "format": "openai"
  },
  "health": {
    "mode": "internal-ready"
  },
  "chat": {
    "path": "chat/completions",
    "streaming": "sse",
    "tools": "supported",
    "system_prompt": "supported"
  }
}
