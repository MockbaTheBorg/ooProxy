{
  "id": "together_ai",
  "match": {
    "schemes": ["https"],
    "host_equals": ["api.together.xyz"],
    "host_suffixes": ["together.xyz"],
    "ports": [443]
  },
  "models": {
    "path": "models",
    "format": "array"
  },
  "health": {
    "mode": "internal-ready"
  },
  "chat": {
    "path": "chat/completions",
    "streaming": "sse",
    "tools": "trial",
    "system_prompt": "supported"
  }
}