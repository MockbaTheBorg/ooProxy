{
  "id": "openrouter",
  "match": {
    "schemes": ["https"],
    "host_equals": ["openrouter.ai"],
    "ports": [443],
    "path_prefixes": ["/api/v1", "/v1"]
  },
  "models": {
    "path": "models",
    "format": "openai"
  },
  "health": {
    "mode": "internal-ready"
  },
  "chat": {
    "path": "chat/completions",
    "streaming": "sse",
    "tools": "supported",
    "system_prompt": "supported"
  }
}